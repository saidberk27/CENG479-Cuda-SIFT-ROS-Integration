# === Build & Install Artifacts ===
build/
install/
log/
colcon_*
*.built_by
COLCON_IGNORE
AMENT_IGNORE
symlink_install_manifest.txt
install_manifest.txt

# === Python ===
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
*.egg
*.whl
.pytest_cache/
.mypy_cache/
.ruff_cache/

# === Compiled Binaries & Libraries ===
*.o
*.obj
*.a
*.so
*.lib
*.dll
*.dylib
*.exe
*.out
*.class

# === CMake ===
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CMakeUserPresets.json
CTestConfiguration.ini
CTestCustom.cmake
CTestTestfile.cmake
Makefile
*.cmake
!**/CMakeLists.txt

# === ROS 2 Generated ===
rosidl_adapter__*.json
rosidl_generator_*__*.json
rosidl_typesupport_*__*.json
*__rosidl_*

# === Output / Data Files ===
**/output/*.png
**/output/*.jpg
**/output/*.jpeg
**/output/*.json
*.bag
*.bag.active

# === Benchmark & Results ===
benchmark_results.json
*.benchmark

# === IDE / Editor ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-*

# === Environment / Virtual Env ===
.env
venv/
.venv/
.envrc
*.env.local

# === Docker ===
.docker/
docker-compose.override.yml

